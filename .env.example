# =============================================================================
# DeFi Signal Terminal — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is in .gitignore.
#
# HOW TO FILL THIS IN:
#   1. Run the AgentMail onboarding scripts in scripts/ to sign up for each
#      service. Each script prints exactly which variable to fill in.
#   2. Paste the key into the matching variable below.
#   3. Re-run `docker-compose up` after editing .env.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE (required — set up by docker-compose, no signup needed)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/defi_signal

# Postgres credentials (must match docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=defi_signal


# -----------------------------------------------------------------------------
# AGENTMAIL  (required for running onboarding scripts)
# Where to get it: https://agentmail.to → Dashboard → API Keys
# What it does: lets the onboarding scripts create inboxes and read
#               verification emails automatically for each service signup.
# -----------------------------------------------------------------------------
AGENTMAIL_API_KEY=


# -----------------------------------------------------------------------------
# APIFY  (required — X/Twitter data ingestion)
# Where to get it: https://console.apify.com → Settings → Integrations → API tokens
# What it does: fetches tweet timelines for your 25 curated accounts every 30 min.
# Cost: $5/month
# AgentMail signup script: scripts/onboard_apify.py
# -----------------------------------------------------------------------------
APIFY_API_TOKEN=


# -----------------------------------------------------------------------------
# ANTHROPIC / CLAUDE  (required — Analyst Copilot briefs)
# Where to get it: https://console.anthropic.com → API Keys
# What it does: generates on-demand research briefs with source citations.
# Cost: pay-per-use, ~$0.06–0.20/day at normal usage
# AgentMail signup script: scripts/onboard_anthropic.py
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# X / TWITTER API  (optional — fallback if Apify breaks)
# Where to get it: https://developer.x.com → Projects & Apps → Keys
# What it does: official tweet timeline access, used as Apify fallback.
# Cost: $100/month (Basic tier)
# Status: apply now at developer.x.com, approval takes 2–7 days
# AgentMail signup script: scripts/onboard_xapi.py
# -----------------------------------------------------------------------------
X_API_BEARER_TOKEN=


# -----------------------------------------------------------------------------
# DUNE  (optional — Coverage Gap analytics, Phase 6)
# Where to get it: https://dune.com → Settings → API → Create API key
# What it does: checks whether a protocol has existing Dune dashboards.
# Cost: free tier (2,500 datapoints/day)
# AgentMail signup script: scripts/onboard_dune.py
# -----------------------------------------------------------------------------
DUNE_API_KEY=


# -----------------------------------------------------------------------------
# DATA PROVIDER  (no key needed — just pick which provider to use)
# Options: "apify" (default) or "xapi" (once X API is approved)
# -----------------------------------------------------------------------------
DATA_PROVIDER=apify


# -----------------------------------------------------------------------------
# APP SETTINGS  (no signup needed)
# -----------------------------------------------------------------------------

# Single token for accessing the internal API.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Paste it here, then use it as the X-Internal-Token header in your browser.
INTERNAL_API_TOKEN=

# How often to poll accounts for new tweets (seconds). Default: 1800 = 30 min.
INGESTION_INTERVAL_SECONDS=1800

# Alert if no new posts ingested within this many minutes.
STALE_DATA_THRESHOLD_MINUTES=120

# LLM model for Analyst Copilot briefs.
COPILOT_MODEL=claude-sonnet-4-6

# Coverage profile cache TTL (seconds). Default: 21600 = 6 hours.
COVERAGE_CACHE_TTL_SECONDS=21600
